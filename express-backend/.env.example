# JWT configuration
JWT_ACCESS_KEY=your_access_token_secret
JWT_REFRESH_KEY=your_refresh_token_secret

# Token expiration
JWT_ACCESS_EXPTIME=15m
JWT_REFRESH_EXPTIME=7d

# Environment for development
NODE_ENV=development

# MongoDB connection
MONGO_URI=mongodb://localhost:27017/tribus-dev

# Example for production (MongoDB Atlas):
# NODE_ENV=production
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/tribus